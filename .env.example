# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google API (credentials file downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials/credentials.json
GOOGLE_TOKEN_FILE=credentials/token.json

# Default Google Drive folder ID to look for content plans
DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Output directory for exported designs
OUTPUT_DIR=output
